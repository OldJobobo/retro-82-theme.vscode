{
  "name": "retro-82-theme",
  "displayName": "Retro '82 Theme",
  "description": "Retro-82 color theme for VS Code",
  "version": "0.1.0",
  "publisher": "oldjobobo",
  "license": "MIT",
  "icon": "icon.png",
  "files": [
    "themes/**",
    "icon.png",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/OldJobobo/omarchy-retro-82-theme.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "scripts": {
    "package": "vsce package --no-dependencies",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "release:patch": "npm version patch && vsce package --no-dependencies",
    "release:minor": "npm version minor && vsce package --no-dependencies",
    "release:major": "npm version major && vsce package --no-dependencies",
    "publish:smart": "bash ./scripts/publish-smart.sh",
    "publish:smart:minor": "bash ./scripts/publish-smart.sh minor",
    "publish:smart:major": "bash ./scripts/publish-smart.sh major",
    "pub": "bash ./scripts/publish-smart.sh",
    "pubm": "bash ./scripts/publish-smart.sh minor",
    "pubM": "bash ./scripts/publish-smart.sh major"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Retro '82",
        "uiTheme": "vs-dark",
        "path": "./themes/base16-retro-82-color-theme.json",
        "semanticHighlighting": true
      }
    ]
  }
}
