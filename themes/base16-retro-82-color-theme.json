  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#134E5A"
      }
    },
    {
      "name": "Variables, Parameters",
      "scope": [
        "variable",
        "string constant.other.placeholder",
        "entity.name.variable.parameter",
        "entity.name.variable.local",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#F85525"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#FAA968"
      }
    },
    {
      "name": "Colors",
      "scope": [
        "constant.other.color"
      ],
